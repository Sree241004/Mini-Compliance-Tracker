generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Client {
  id           Int     @id @default(autoincrement())
  company_name String
  country      String
  entity_type  String
  tasks        Task[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  category    String
  due_date    DateTime
  status      String
  priority    String

  client_id Int
  client    Client @relation(fields: [client_id], references: [id])
}